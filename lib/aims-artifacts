#!/usr/bin/env bash
set -euo pipefail
# aims artifacts <session-id>
# Print (and create) this session's directory in the shared large-file store. The store is optional;
# it must be mounted locally and pointed to by AIMS_ARTIFACTS. See docs/SHARED-STORE.md for backends
# (NFS, SMB, GlusterFS, CephFS, MinIO, RustFS, Ceph RGW). Git keeps pointers; the store keeps bytes.
sid="${1:-}"
[ -n "$sid" ] || { echo "usage: aims artifacts <session-id>" >&2; exit 2; }
sid="${sid#ai/}"
[[ "$sid" =~ ^[A-Za-z0-9._-]+$ ]] || { echo "ERROR: unsafe session id: $sid" >&2; exit 2; }
store="${AIMS_ARTIFACTS:-}"
[ -n "$store" ] || { echo "ERROR: AIMS_ARTIFACTS is not set (see docs/SHARED-STORE.md)" >&2; exit 1; }
[ -d "$store" ] || { echo "ERROR: AIMS_ARTIFACTS ($store) is not mounted or does not exist" >&2; exit 1; }
dir="$store/$sid"
mkdir -p "$dir"
echo "$dir"
