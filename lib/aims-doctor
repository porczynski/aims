#!/usr/bin/env bash
set -uo pipefail
home="${AIMS_HOME:-$HOME/.aims}"; fail=0
ok(){ printf 'OK: %s\n' "$*"; }; err(){ printf 'ERROR: %s\n' "$*"; fail=1; }; warn(){ printf 'WARN: %s\n' "$*"; }
command -v git >/dev/null && ok "git present" || err "git missing"
command -v bash >/dev/null && ok "bash present" || err "bash missing"
command -v python3 >/dev/null && ok "python3 present" || err "python3 missing (aims-publish/list need it)"
[ -d "$home/.git" ] && ok "data repo $home" || err "no data repo at $home (run: aims init)"
[ -f "$home/SESSIONS.md" ] && ok "registry present" || warn "SESSIONS.md missing"
if [ -d "$home/.git" ]; then
  git -C "$home" remote get-url origin >/dev/null 2>&1 && ok "origin remote set" || warn "no origin remote (single-machine only until set)"
fi
if [ -n "${AIMS_ARTIFACTS:-}" ]; then
  [ -d "$AIMS_ARTIFACTS" ] && ok "artifact store mounted: $AIMS_ARTIFACTS" || warn "AIMS_ARTIFACTS set but not mounted: $AIMS_ARTIFACTS"
else
  warn "AIMS_ARTIFACTS not set (optional shared large-file store; see docs/SHARED-STORE.md)"
fi
[ "$fail" -eq 0 ] && ok "aims doctor passed" || { err "issues found"; exit 1; }
