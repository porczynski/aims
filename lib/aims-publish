#!/usr/bin/env bash
set -euo pipefail
arg="${1:-}"
[ -n "$arg" ] || { echo "usage: aims publish <session-id|ai/session-id>" >&2; exit 2; }
repo="${AIMS_HOME:-$HOME/.aims}"
branch="$arg"; [[ "$branch" == ai/* ]] || branch="ai/$arg"
sid="${branch#ai/}"
[[ "$sid" =~ ^[A-Za-z0-9._-]+$ ]] || { echo "ERROR: unsafe session id: $sid" >&2; exit 2; }
git -C "$repo" remote get-url origin >/dev/null 2>&1 || { echo "ERROR: data repo $repo has no 'origin' remote — publish integrates the session through origin/main. Add one:" >&2; echo "  git -C \"$repo\" remote add origin <url> && git -C \"$repo\" push -u origin main" >&2; exit 1; }
git -C "$repo" config user.name  >/dev/null 2>&1 || export GIT_AUTHOR_NAME="${AIMS_GIT_NAME:-AIMS Agent}"    GIT_COMMITTER_NAME="${AIMS_GIT_NAME:-AIMS Agent}"      # fresh machine may have no git identity (merge + registry commits)
git -C "$repo" config user.email >/dev/null 2>&1 || export GIT_AUTHOR_EMAIL="${AIMS_GIT_EMAIL:-aims@localhost}" GIT_COMMITTER_EMAIL="${AIMS_GIT_EMAIL:-aims@localhost}"  # fall back only when unset (real identity is kept)
pub="$repo/.worktrees/_publish-$sid"
agent_wt="$repo/.worktrees/$sid"
if [ -d "$agent_wt" ]; then                                    # guard: publish used to force-remove the worktree and silently destroy uncommitted/unpushed work.
  if [ -n "$(git -C "$agent_wt" status --porcelain)" ]; then
    echo "REFUSE: worktree $agent_wt has UNCOMMITTED changes. Run 'aims save' in it, then retry publish (prevents silent data loss)." >&2; exit 1
  fi
  git -C "$repo" fetch -q origin "$branch" 2>/dev/null || true
  if git rev-parse --verify --quiet "origin/$branch" >/dev/null && [ -n "$(git -C "$agent_wt" rev-list "origin/$branch..HEAD" 2>/dev/null)" ]; then
    echo "REFUSE: worktree $agent_wt has commits NOT pushed to origin. Run 'aims save' (publish merges the origin state)." >&2; exit 1
  fi
fi
cleanup_fail() {  # on merge/push failure: leave the repo clean + tell the agent what to do
  git -C "$pub" merge --abort 2>/dev/null || true
  git -C "$repo" worktree remove "$pub" --force 2>/dev/null || true
  git -C "$repo" branch -D "publish/$sid" 2>/dev/null || true
  echo "ERROR: publish failed for $sid. Fix: in your worktree run 'git fetch origin main && git rebase origin/main', resolve conflicts, 'aims save', then retry aims publish." >&2
  exit 1
}
git -C "$repo" fetch origin main "$branch"
rm -rf "$pub"
git -C "$repo" worktree add "$pub" -b "publish/$sid" origin/main
pub_base="$(git -C "$pub" rev-parse HEAD)"   # base to detect an "empty" merge
git -C "$pub" merge --no-ff "origin/$branch" -m "📝 session: merge $sid" || cleanup_fail
if [ -z "$(git -C "$pub" diff --name-only "$pub_base" HEAD)" ]; then    # guard: an empty merge used to look like success.
  echo "WARNING: merge of $sid brought NO file changes — the session may not have pushed its work (aims save?). Verify before treating it as published." >&2
fi
if [ -f "$pub/sessions/work/$sid/metadata.json" ] && ! grep -q "$sid" "$pub/SESSIONS.md" 2>/dev/null; then  # auto-append registry row unless the agent added one
  meta="$pub/sessions/work/$sid/metadata.json"
  read -r proj topic started < <(python3 -c 'import json,sys; m=json.load(open(sys.argv[1])); print(m["project"], m["topic"], m["started_at"])' "$meta")
  last_n="$(grep -oE '^\| s[0-9]+' "$pub/SESSIONS.md" | grep -oE '[0-9]+' | sort -n | tail -1 || echo 0)"
  snn="s$(printf '%03d' $(( ${last_n:-0} + 1 )))"
  printf '| %s | %s | %s | %s | %s | sessions/work/%s/ | — | done |\n' "$snn" "${started:0:10}" "${started:11:5}" "$proj" "$topic" "$sid" >> "$pub/SESSIONS.md"
  git -C "$pub" add SESSIONS.md && git -C "$pub" commit -m "📝 registry: $snn $sid" -q
fi
AIMS_PUBLISH=1 git -C "$pub" push origin HEAD:main || cleanup_fail
git -C "$repo" push origin --delete "$branch" || true
echo "--- merged to main (full session diff, not just the registry row):"
git -C "$pub" diff --stat "$pub_base" HEAD 2>/dev/null | tail -25 || true
git -C "$repo" worktree remove "$pub" --force
[ -d "$agent_wt" ] && git -C "$repo" worktree remove "$agent_wt" --force || true
echo "OK: published $sid to main"
